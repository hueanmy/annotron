{
  "name": "annotron",
  "version": "0.6.0",
  "description": "Local, browser-based review editor for agent-generated HTML artifacts — annotate elements and text, send feedback to your AI coding agent, then finalize the result into the file and download it.",
  "type": "module",
  "bin": {
    "annotron": "bin/annotron"
  },
  "files": [
    "bin/",
    "src/",
    "skills/",
    "commands/",
    "hooks/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hueanmy/annotron.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "claude-code",
    "claude-plugin",
    "html",
    "artifacts",
    "annotation",
    "code-review",
    "ai-agents",
    "developer-tools",
    "cli",
    "feedback",
    "llm"
  ],
  "author": "Meii",
  "license": "MIT"
}
